---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  /** Page language. Site is English; the "A Grande Caminhada" page passes "pt-BR". */
  lang?: string;
}

const { title, description, ogImage = 'og-image.png', lang = 'en' } = Astro.props;

// Base-aware asset paths. `base` is currently "/Jatahy.me"; switching to "/" for the
// custom domain updates every path here automatically.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${base}/${p.replace(/^\//, '')}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogUrl = new URL(asset(ogImage), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index,follow" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogUrl} />

  <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
  <meta name="theme-color" content="#0e0d0a" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>
