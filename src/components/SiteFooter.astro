---
const year = new Date().getFullYear();
const socials = [
  { href: 'https://x.com/edujatahy', label: 'X' },
  { href: 'https://github.com/edujatahy', label: 'GitHub' },
  { href: 'mailto:site@jatahy.me', label: 'Email' },
];
---

<footer class="border-t border-border">
  <div class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 px-5 py-10 text-sm text-fg-muted sm:flex-row sm:items-center sm:px-8">
    <div>© {year} Eduardo Jatahy</div>
    <div class="flex items-center gap-5">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" class="transition-colors hover:text-gold">{s.label}</a>
      ))}
    </div>
  </div>
</footer>
